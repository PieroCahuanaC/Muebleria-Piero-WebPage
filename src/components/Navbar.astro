---
import "/src/styles/global.css";
import CartIconWrapper from "./CartIconWrapper.jsx";

---

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const menuBtn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    menuBtn.addEventListener("click", function () {
      mobileMenu.classList.toggle("hidden");
    });
  });
</script>

<nav class="bg-white border-b border-gray-200">
  <div class="mx-auto max-w-7xl px-2 sm:px-6 lg:px-8">
    <div class="relative flex h-16 items-center justify-between">
      <div class="absolute inset-y-0 left-0 flex items-center sm:hidden">
        <!-- Botón de menú hamburguesa -->
        <button
          id="menu-btn"
          type="button"
          class="relative inline-flex items-center justify-center rounded-md p-2 text-gray-600 hover:bg-gray-200 hover:text-gray-900 focus:ring-2 focus:ring-gray-500 focus:outline-none focus:ring-inset"
          aria-controls="mobile-menu"
          aria-expanded="false"
        > 
        
          <span class="absolute -inset-0.5"></span>
          <span class="sr-only">Open main menu</span>
          <svg
            class="block size-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true"
            data-slot="icon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
          </svg>
        </button>
      </div>
      <div
        class="flex flex-1 items-center justify-center sm:items-stretch sm:justify-start"
      >
        <div class="flex shrink-0 items-center">
          <a href="/">
            <img class="h-7 sm:h-10 w-auto" src="/logo.png" alt="logo" />
          </a>
        </div>

        <div class="hidden sm:block w-full">
          <div class="flex justify-center space-x-4">
            <a
              href="/categorias/dormitorio"
              class="rounded-md px-3 py-2 text-sm font-medium text-gray-900 hover:bg-gray-200 hover:text-gray-900"
              >Dormitorio</a
            >
            <a
              href="/categorias/cocina-y-comedor"
              class="rounded-md px-3 py-2 text-sm font-medium text-gray-900 hover:bg-gray-200 hover:text-gray-900"
              >Cocina y comedor</a
            >
            <a
              href="/categorias/oficina"
              class="rounded-md px-3 py-2 text-sm font-medium text-gray-900 hover:bg-gray-200 hover:text-gray-900"
              >Oficina</a
            >
          </div>
        </div>
      </div>
      <div
        class="absolute inset-y-0 right-0 flex items-center space-x-3 pr-2 sm:static sm:inset-auto sm:ml-6 sm:pr-0"
      >
        <!-- ✅ Carrito corregido -->

        <CartIconWrapper client:load />

        <!-- Lupa 
        <a href="/">
          <div
            class="relative rounded-full bg-white p-1 text-gray-600 hover:text-gray-900 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 focus:ring-offset-white"
          >
            <span class="absolute -inset-1.5"></span>
            <span class="sr-only">Search</span>
            <img class="h-7 w-auto" src="/lupa.png" alt="search" />
          </div>
        </a>
        -->
      </div>
    </div>
  </div>
</nav>

<!-- Mobile menu -->
<div class="sm:hidden hidden" id="mobile-menu">
  <div class="space-y-1 px-2 pt-2 pb-3">
    <a
      href="/categorias/dormitorio"
      class="block rounded-md bg-gray-100 px-3 py-2 text-base font-medium text-gray-900"
      >Dormitorio</a
    >
    <a
      href="/categorias/cocina-y-comedor"
      class="block rounded-md px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-200"
      >Cocina y comedor</a
    >
    <a
      href="/categorias/oficina"
      class="block rounded-md px-3 py-2 text-base font-medium text-gray-900 hover:bg-gray-200"
      >Oficina</a
    >
  </div>
</div>
